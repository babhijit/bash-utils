# =============================================================================
# selective_copy.conf.example — job config for selective_copy.sh
#
# Copy to e.g. selective_copy.conf, edit for your job, then:
#   # as the SOURCE user (e.g. opc_d1):
#   bash selective_copy.sh --mode prepare --config ./selective_copy.conf \
#        --source-user opc_d1 --target-user opc_d2
#   # as the TARGET user (e.g. opc_d2):
#   bash selective_copy.sh --mode deploy  --config ./selective_copy.conf \
#        --target-user opc_d2 --staging-dir /tmp/test_f2/migration
#
# This file is SOURCED AS BASH by selective_copy.sh — use only operator-authored
# configs (same trust level as the script). Variables you omit default to empty
# (no items) / mktemp staging. CLI flags (--source-base/--target-base/
# --staging-dir) override anything set here.
# =============================================================================

# --- Base directories -------------------------------------------------------
# prepare reads under SOURCE_BASE_DIR and records TARGET_BASE_DIR for deploy;
# deploy writes under TARGET_BASE_DIR. No hardcoded defaults — set them here.
SOURCE_BASE_DIR="/applications/opc_d1"
TARGET_BASE_DIR="/applications/opc_d2"

# --- Staging directory (optional) -------------------------------------------
# The /tmp handoff area prepare writes and deploy reads. Leave unset to have
# prepare mktemp a fresh /tmp/scopy.XXXX and print it; set it for a fixed,
# predictable path (must be empty/absent when prepare runs).
STAGING_DIR="/tmp/test_f2/migration"

# --- Items to copy ----------------------------------------------------------
# "src_name|dest_name": src_name relative to SOURCE_BASE_DIR, dest_name relative
# to TARGET_BASE_DIR. (Mirror the convention your deploy expects.)
COPY_MAPPING=(
    "bin|bin/"
    "etc|etc/"
    "security|security/"
)

# --- Symlinks to (re)create at the target -----------------------------------
# "src_link|dest_link|dest_target"
SYMBOLIC_LINK_MAPPING=()

# --- rsync exclusions, per source item --------------------------------------
# "src_name:relative_pattern"
EXCLUDE_MAPPING=(
    "bin:*.log"
)

# --- Post-copy renames / symlink retargets at the target --------------------
# "rel_path|new_name|new_link_target"  (empty new_link_target = plain rename)
NESTED_ITEM_TRANSFORM=()
